# Local development overrides - DO NOT COMMIT
# Copy this file to application-local.properties and fill in your values
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
JWT_SECRET=your-base64-encoded-jwt-secret

# ElevenLabs
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key

# Backblaze B2
B2_S3_ENDPOINT=https://s3.<region>.backblazeb2.com
B2_BUCKET=your-bucket-name
B2_ACCESS_KEY=your-b2-access-key
B2_SECRET_KEY=your-b2-secret-key
